{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "claude-flow-studio",
  "version": "0.1.0",
  "identifier": "dev.damiansire.claude-flow-studio",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "claude-flow-studio",
        "width": 1200,
        "height": 800
      }
    ],
    "security": {
      "capabilities": ["claude-config-access"]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}
